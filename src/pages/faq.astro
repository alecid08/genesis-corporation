---
import Layout from '../layouts/Layout.astro';
import FAQItem from '../components/FAQItem.astro';

const generalFaqs = [
  {
    question: '¿Cuál es su área de servicio en Miami?',
    answer: 'Genesis Electrical Corporation sirve a todo el condado de Miami-Dade, incluyendo Coral Gables, Coconut Grove, Pinecrest, Doral y Miami Beach. También cubrimos áreas seleccionadas del sur de Broward para proyectos comerciales de gran escala.'
  },
  {
    question: '¿Están disponibles para emergencias 24/7?',
    answer: 'Sí, contamos con un equipo de guardia los 365 días del año. Las emergencias eléctricas no esperan, y nosotros tampoco. Puede contactarnos directamente al <strong>(786) 720-2328</strong> para asistencia inmediata.'
  },
  {
    question: '¿Tienen licencia y seguro en Florida?',
    answer: 'Absolutamente. Genesis Electrical Corporation es una empresa totalmente certificada y asegurada (Florida Electrical Contractor License #EC1300XXXX). Cumplimos con todos los estándares del NEC (National Electrical Code) y las regulaciones locales de construcción.'
  }
];

const serviceFaqs = [
  {
    question: '¿Realizan instalaciones de cargadores para vehículos eléctricos?',
    answer: 'Somos instaladores certificados para Tesla Wall Connector y otras marcas principales como ChargePoint y JuiceBox. Realizamos el estudio de carga de su panel existente y gestionamos los permisos necesarios.'
  },
  {
    question: '¿Qué incluye un mantenimiento preventivo comercial?',
    answer: 'Nuestros planes incluyen termografía infrarroja para detectar puntos calientes, torqueo de conexiones, limpieza de paneles y pruebas de sistemas de emergencia/iluminación de salida para cumplir con las normativas locales y OSHA.'
  }
];

const paymentFaqs = [
  {
    question: '¿Qué métodos de pago aceptan?',
    answer: 'Aceptamos todas las tarjetas de crédito principales, Zelle, transferencias ACH y cheques corporativos. Para proyectos residenciales grandes, ofrecemos opciones de financiamiento a través de socios seleccionados.'
  }
];
---

<Layout 
  title="Preguntas Frecuentes | Genesis Electrical Corporation"
  description="Encuentre respuestas rápidas a sus dudas sobre instalaciones, tarifas de emergencia 24/7, mantenimiento y licencias de Genesis Electrical Corporation en Miami."
>
  <!-- Hero Header -->
  <section class="relative h-[400px] flex items-center justify-center overflow-hidden pt-20">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAxQ4ExkzcFtlvigTmakzdIxlno5HJz3coU52CAtBM2GeYDnuEM5kN_7YcFB3TLYj5zAA9Re1z4RfiFy3mx0Zoj8RoIjynlQbUUPNfei_mWGsgICAInFMy7RWMXEhr1ZOUO4vQQ97kz4mSjLYd0QeL12WdUrjzOTPo1A8lzu85AgCkzE0BSvw2J9Af_HDA_QpQDyChofha4DFx-Luit5Ck1wn_QEB783smtzYGBLXG3apxdIBGG-ChL30ZecedXkyciOlRABkrRS7s')"></div>
    <div class="absolute inset-0 bg-deep-navy/70 backdrop-blur-[2px]"></div>
    <div class="relative z-10 text-center px-margin-mobile">
      <h1 class="font-display-lg text-white text-display-lg-mobile md:text-5xl font-bold mb-4">Preguntas Frecuentes</h1>
      <p class="text-white/90 font-body-lg max-w-2xl mx-auto">Encuentra respuestas rápidas a tus dudas sobre instalaciones, mantenimiento y servicios de emergencia en Miami.</p>
    </div>
  </section>

  <!-- Search Section -->
  <section class="relative -mt-12 z-20 px-margin-mobile max-w-container-max mx-auto">
    <div class="bg-white shadow-lg rounded-2xl p-6 md:p-10 border border-outline-variant/30 max-w-3xl mx-auto">
      <div class="relative flex items-center">
        <span class="absolute left-6 material-symbols-outlined text-outline text-2xl select-none">search</span>
        <input 
          id="faq-search"
          class="w-full pl-16 pr-6 py-5 bg-surface-container-low border-2 border-transparent focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none rounded-xl font-body-lg text-on-surface transition-all placeholder:text-outline" 
          placeholder="¿Cómo podemos ayudarte hoy?" 
          type="text"
        />
      </div>
      <div class="mt-4 flex flex-wrap gap-2 justify-center items-center">
        <span class="text-label-md text-outline">Búsquedas populares:</span>
        <button class="popular-search text-label-md text-electric-blue font-semibold hover:underline">Certificación FPL</button>
        <span class="text-outline text-xs">•</span>
        <button class="popular-search text-label-md text-electric-blue font-semibold hover:underline">Tarifas de emergencia</button>
        <span class="text-outline text-xs">•</span>
        <button class="popular-search text-label-md text-electric-blue font-semibold hover:underline">Cargadores Tesla</button>
      </div>
    </div>
  </section>

  <!-- FAQ Accordions -->
  <main class="py-24 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
      <!-- Category Navigation -->
      <aside class="lg:col-span-3 space-y-2 lg:sticky lg:top-24 h-fit">
        <h3 class="font-headline-lg text-deep-navy mb-6 px-4 font-bold text-xl">Categorías</h3>
        <a href="#general" class="w-full text-left p-4 rounded-lg bg-electric-blue text-white font-bold flex items-center justify-between group transition-all">
          <span>General</span>
          <span class="material-symbols-outlined select-none">chevron_right</span>
        </a>
        <a href="#servicios" class="w-full text-left p-4 rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-all flex items-center justify-between font-medium group">
          <span>Servicios e Instalaciones</span>
          <span class="material-symbols-outlined select-none opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
        </a>
        <a href="#pagos" class="w-full text-left p-4 rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-all flex items-center justify-between font-medium group">
          <span>Pagos y Garantía</span>
          <span class="material-symbols-outlined select-none opacity-0 group-hover:opacity-100 transition-opacity">chevron_right</span>
        </a>
      </aside>

      <!-- FAQ Content -->
      <div class="lg:col-span-9 space-y-16">
        <!-- General Section -->
        <section id="general" class="faq-section scroll-mt-28">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-electric-blue/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-electric-blue select-none">info</span>
            </div>
            <h2 class="font-headline-lg text-deep-navy font-bold text-2xl">Información General</h2>
          </div>
          <div class="space-y-4">
            {generalFaqs.map((faq) => (
              <FAQItem question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </section>

        <!-- Services Section -->
        <section id="servicios" class="faq-section scroll-mt-28">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-electric-blue/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-electric-blue select-none">bolt</span>
            </div>
            <h2 class="font-headline-lg text-deep-navy font-bold text-2xl">Servicios e Instalaciones</h2>
          </div>
          <div class="space-y-4">
            {serviceFaqs.map((faq) => (
              <FAQItem question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </section>

        <!-- Payments Section -->
        <section id="pagos" class="faq-section scroll-mt-28">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-xl bg-electric-blue/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-electric-blue select-none">payments</span>
            </div>
            <h2 class="font-headline-lg text-deep-navy font-bold text-2xl">Pagos y Garantía</h2>
          </div>
          <div class="space-y-4">
            {paymentFaqs.map((faq) => (
              <FAQItem question={faq.question} answer={faq.answer} />
            ))}
          </div>
        </section>
        
        <!-- No Results Message -->
        <div id="no-results" class="hidden text-center py-12 text-on-surface-variant">
          <span class="material-symbols-outlined text-5xl mb-4 text-outline select-none">search_off</span>
          <p class="text-lg font-bold">No se encontraron preguntas que coincidan con su búsqueda.</p>
          <p class="text-sm mt-2">Intente usar palabras clave más generales como "licencia", "emergencia" o "Tesla".</p>
        </div>
      </div>
    </div>
  </main>

  <!-- Final CTA Section -->
  <section class="py-24 bg-deep-navy text-on-primary">
    <div class="px-base md:px-margin-desktop max-w-container-max mx-auto text-center">
      <h2 class="font-headline-lg text-headline-xl mb-6 font-bold text-3xl">¿No encontraste lo que buscabas?</h2>
      <p class="text-body-lg mb-10 max-w-xl mx-auto opacity-90">Nuestro equipo está a tu disposición para aclarar cualquier duda técnica o comercial de forma inmediata.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-6">
        <a href="tel:+17867202328" class="bg-safety-yellow text-deep-navy px-10 py-4 rounded-lg font-bold hover:scale-105 transition-transform flex items-center justify-center gap-2">
          <span class="material-symbols-outlined">call</span> (786) 720-2328
        </a>
        <a href="/contacto" class="bg-transparent border-2 border-white text-white px-10 py-4 rounded-lg font-bold hover:bg-white/10 transition-colors flex items-center justify-center gap-2">
          <span class="material-symbols-outlined">mail</span> Enviar Mensaje
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Search Filter functionality
  const searchInput = document.getElementById('faq-search') as HTMLInputElement;
  const faqItems = document.querySelectorAll('.faq-item');
  const sections = document.querySelectorAll('.faq-section');
  const noResults = document.getElementById('no-results');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase().trim();
      let matches = 0;

      faqItems.forEach((item) => {
        const questionText = item.querySelector('.faq-toggle')?.textContent?.toLowerCase() || '';
        const answerText = item.querySelector('.faq-content')?.textContent?.toLowerCase() || '';

        if (questionText.includes(query) || answerText.includes(query)) {
          item.classList.remove('hidden');
          matches++;
        } else {
          item.classList.add('hidden');
        }
      });

      // Show/Hide section headers depending on if they have visible items
      sections.forEach((section) => {
        const visibleItems = section.querySelectorAll('.faq-item:not(.hidden)');
        if (visibleItems.length === 0 && query !== '') {
          section.classList.add('hidden');
        } else {
          section.classList.remove('hidden');
        }
      });

      // Show no results message if nothing matches
      if (matches === 0 && query !== '') {
        noResults?.classList.remove('hidden');
      } else {
        noResults?.classList.add('hidden');
      }
    });
  }

  // popular search click behavior
  const popularTags = document.querySelectorAll('.popular-search');
  popularTags.forEach(tag => {
    tag.addEventListener('click', () => {
      let queryText = tag.textContent || '';
      if (queryText === 'Certificación FPL') queryText = 'licencia';
      if (queryText === 'Tarifas de emergencia') queryText = 'emergencia';
      if (queryText === 'Cargadores Tesla') queryText = 'Tesla';
      
      if (searchInput) {
        searchInput.value = queryText;
        searchInput.dispatchEvent(new Event('input'));
        searchInput.focus();
      }
    });
  });
</script>
