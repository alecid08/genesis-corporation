---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import homeHeroImage from '../assets/home-hero.jpg';
import serviceAreaImage from '../assets/service-area.jpg';

const title = "Genesis Electrical Corporation | Electricistas Profesionales en Miami";
const description = "Genesis Electrical Corporation - Electricistas Profesionales en Miami, Florida. Servicios residenciales, comerciales y emergencias.";

const base = import.meta.env.BASE_URL;
const getPath = (href: string) => {
  if (href.startsWith('/')) {
    return `${base.replace(/\/$/, '')}${href}`;
  }
  return href;
};
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="relative h-[819px] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image 
        src={homeHeroImage} 
        alt="Electricista profesional en Miami trabajando en un panel eléctrico moderno" 
        class="w-full h-full object-cover" 
        loading="eager" 
        fetchpriority="high"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 bg-primary/40 mix-blend-multiply"></div>
    </div>
    <div class="relative z-10 px-base md:px-margin-desktop max-w-container-max mx-auto w-full">
      <div class="max-w-2xl text-on-primary">
        <h1 class="font-display-lg text-[60px] leading-[1.1] font-bold mb-6">
          Genesis Electrical Corporation
        </h1>
        <p class="font-headline-md text-headline-md mb-8 opacity-90">
          Electricistas Profesionales en Miami, Florida
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={getPath('/servicios')} class="bg-safety-yellow text-deep-navy font-bold py-4 px-8 rounded-lg shadow-lg hover:brightness-95 transition-all text-lg inline-block text-center">
            Nuestros Servicios
          </a>
          <a href={getPath('/contacto')} class="bg-transparent border-2 border-white text-white font-bold py-4 px-8 rounded-lg hover:bg-white/10 transition-all text-lg inline-block text-center">
            Solicitar Presupuesto
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿Por Qué Elegirnos? -->
  <section class="py-24 bg-surface-subtle">
    <div class="px-base md:px-margin-desktop max-w-container-max mx-auto">
      <h2 class="font-headline-lg text-headline-lg text-deep-navy text-center mb-16">¿Por Qué Elegirnos?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        <!-- Feature Cards -->
        <div class="bg-surface-container-low p-8 rounded-xl shadow-md border-t-4 border-transparent hover:border-electric-blue transition-all group">
          <span class="material-symbols-outlined text-4xl text-electric-blue mb-4 block">verified_user</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-3">Licenciados</h3>
          <p class="text-on-surface-variant font-body-md">Personal certificado y totalmente asegurado para su total tranquilidad en cada proyecto.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-xl shadow-md border-t-4 border-transparent hover:border-electric-blue transition-all">
          <span class="material-symbols-outlined text-4xl text-electric-blue mb-4 block">calendar_today</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-3">7 Días</h3>
          <p class="text-on-surface-variant font-body-md">Disponibilidad total los 7 días de la semana para atender cualquier necesidad eléctrica urgente.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-xl shadow-md border-t-4 border-transparent hover:border-electric-blue transition-all">
          <span class="material-symbols-outlined text-4xl text-electric-blue mb-4 block">payments</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-3">Precios</h3>
          <p class="text-on-surface-variant font-body-md">Tarifas competitivas y presupuestos transparentes sin cargos ocultos ni sorpresas finales.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-xl shadow-md border-t-4 border-transparent hover:border-electric-blue transition-all">
          <span class="material-symbols-outlined text-4xl text-electric-blue mb-4 block">engineering</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-3">Experiencia</h3>
          <p class="text-on-surface-variant font-body-md">Años de trayectoria resolviendo los retos eléctricos más complejos en todo Miami-Dade.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-xl shadow-md border-t-4 border-transparent hover:border-electric-blue transition-all">
          <span class="material-symbols-outlined text-4xl text-electric-blue mb-4 block">workspace_premium</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-3">Garantía</h3>
          <p class="text-on-surface-variant font-body-md">Respaldamos cada trabajo con garantías sólidas que certifican nuestra calidad y compromiso.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-xl shadow-md border-t-4 border-transparent hover:border-electric-blue transition-all">
          <span class="material-symbols-outlined text-4xl text-electric-blue mb-4 block">person_search</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-3">Personalizado</h3>
          <p class="text-on-surface-variant font-body-md">Soluciones a medida diseñadas específicamente para sus necesidades residenciales o comerciales.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios Principales -->
  <section class="py-24 bg-white">
    <div class="px-base md:px-margin-desktop max-w-container-max mx-auto">
      <h2 class="font-headline-lg text-headline-lg text-deep-navy text-center mb-16">Servicios Principales</h2>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Residencial -->
        <div class="glass-card p-10 rounded-2xl shadow-xl hover:-translate-y-2 transition-all">
          <span class="material-symbols-outlined text-[80px] text-electric-blue mb-6">home</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-6">Residencial</h3>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Instalaciones de Iluminación LED</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Actualización de Paneles Eléctricos</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Instalación de Ventiladores de Techo</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Reparación de Cableado Antiguo</span></li>
          </ul>
        </div>
        <!-- Comercial -->
        <div class="glass-card p-10 rounded-2xl shadow-xl hover:-translate-y-2 transition-all">
          <span class="material-symbols-outlined text-[80px] text-electric-blue mb-6">business</span>
          <h3 class="font-headline-md text-headline-md text-deep-navy mb-6">Comercial</h3>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Mantenimiento Preventivo Industrial</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Sistemas Eléctricos Trifásicos</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Iluminación de Seguridad y Exterior</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-success-green">check_circle</span> <span class="font-body-md text-on-surface">Auditorías de Eficiencia Energética</span></li>
          </ul>
        </div>
        <!-- Emergencia -->
        <div class="glass-card p-10 rounded-2xl shadow-xl hover:-translate-y-2 transition-all bg-emergency-red/5 border-emergency-red/20">
          <span class="material-symbols-outlined text-[80px] text-emergency-red mb-6" style="font-variation-settings: 'FILL' 1;">warning</span>
          <h3 class="font-headline-md text-headline-md text-emergency-red mb-6">Emergencia 24/7</h3>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-emergency-red">emergency_home</span> <span class="font-body-md text-on-surface">Reparación Inmediata de Apagones</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-emergency-red">emergency_home</span> <span class="font-body-md text-on-surface">Cortocircuitos y Fallos de Panel</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-emergency-red">emergency_home</span> <span class="font-body-md text-on-surface">Atención en Menos de 60 Minutos</span></li>
            <li class="flex items-start gap-3"><span class="material-symbols-outlined text-emergency-red">emergency_home</span> <span class="font-body-md text-on-surface">Servicio en Toda el Área de Miami</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonios -->
  <section class="py-24 bg-electric-blue">
    <div class="px-base md:px-margin-desktop max-w-container-max mx-auto text-on-primary">
      <h2 class="font-headline-lg text-headline-lg text-center mb-16">Lo Que Dicen Nuestros Clientes</h2>
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-gutter pb-8 no-scrollbar">
        <!-- Testimonial 1 -->
        <div class="min-w-full md:min-w-[400px] snap-center bg-white/10 backdrop-blur p-8 rounded-2xl">
          <div class="flex text-safety-yellow mb-4">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <p class="font-body-lg italic mb-6">"Excelente servicio. Llegaron a tiempo para una emergencia eléctrica en mi negocio y resolvieron todo rápidamente. Muy profesionales y amables."</p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center text-deep-navy font-bold">RL</div>
            <div>
              <p class="font-label-lg">Ricardo L.</p>
              <p class="text-sm opacity-80">Coral Gables, FL</p>
            </div>
          </div>
        </div>
        <!-- Testimonial 2 -->
        <div class="min-w-full md:min-w-[400px] snap-center bg-white/10 backdrop-blur p-8 rounded-2xl">
          <div class="flex text-safety-yellow mb-4">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <p class="font-body-lg italic mb-6">"Instalaron toda la iluminación nueva en mi casa. El trabajo fue impecable y el precio muy justo. Definitivamente los recomiendo para cualquier trabajo residencial."</p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center text-deep-navy font-bold">MC</div>
            <div>
              <p class="font-label-lg">Maria C.</p>
              <p class="text-sm opacity-80">Doral, FL</p>
            </div>
          </div>
        </div>
        <!-- Testimonial 3 -->
        <div class="min-w-full md:min-w-[400px] snap-center bg-white/10 backdrop-blur p-8 rounded-2xl">
          <div class="flex text-safety-yellow mb-4">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <p class="font-body-lg italic mb-6">"Genesis Electrical es mi opción de confianza. Son honestos, directos y saben exactamente lo que hacen. La garantía que ofrecen da mucha tranquilidad."</p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center text-deep-navy font-bold">JH</div>
            <div>
              <p class="font-label-lg">John H.</p>
              <p class="text-sm opacity-80">Miami Beach, FL</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Área de Servicio -->
  <section class="py-24">
    <div class="flex flex-col lg:flex-row h-full">
      <!-- Map Column -->
      <div class="w-full lg:w-1/2 h-[500px] lg:h-auto min-h-[400px] relative">
        <Image 
          src={serviceAreaImage} 
          alt="Mapa de área de servicio de electricistas en Miami" 
          class="w-full h-full object-cover absolute inset-0"
          loading="lazy"
          decoding="async"
          width={800}
          height={600}
        />
      </div>
      <!-- Service List Column -->
      <div class="w-full lg:w-1/2 px-base md:px-margin-desktop py-12 bg-deep-navy text-on-primary">
        <h2 class="font-headline-lg text-headline-lg mb-8">Nuestra Área de Servicio</h2>
        <p class="font-body-lg mb-8 opacity-90">Atendemos a toda la comunidad de Miami-Dade con tiempos de respuesta rápidos y equipo local.</p>
        <div class="grid grid-cols-2 gap-4">
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Miami Beach</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Coral Gables</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Doral</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Hialeah</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Kendall</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Homestead</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Aventura</div>
          <div class="flex items-center gap-2"><span class="material-symbols-outlined text-safety-yellow">location_on</span> Pinecrest</div>
        </div>
        <div class="mt-12 p-6 bg-white/10 rounded-lg border border-white/20">
          <p class="font-bold font-label-lg mb-2">Sede Principal:</p>
          <p class="font-body-md opacity-80 italic text-safety-yellow">185 NW 13th Ave, Miami, FL 33125</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-24 bg-gradient-to-r from-deep-navy via-primary to-electric-blue text-on-primary">
    <div class="px-base md:px-margin-desktop max-w-container-max mx-auto text-center">
      <h2 class="font-display-lg text-display-lg-mobile md:text-display-lg mb-6">¿Listo para solucionar sus problemas eléctricos?</h2>
      <p class="font-body-lg text-lg mb-12 max-w-2xl mx-auto">No arriesgue su seguridad. Contacte hoy mismo a los expertos licenciados de Genesis Electrical Corporation.</p>
      <div class="flex flex-wrap justify-center gap-6">
        <a class="bg-safety-yellow text-deep-navy font-bold py-5 px-10 rounded-full shadow-2xl hover:scale-105 transition-all flex items-center gap-3" href="tel:7867202328">
          <span class="material-symbols-outlined">call</span> Llamar Ahora
        </a>
        <a class="bg-white text-deep-navy font-bold py-5 px-10 rounded-full shadow-2xl hover:scale-105 transition-all flex items-center gap-3" href={getPath('/contacto')}>
          <span class="material-symbols-outlined">chat</span> Enviar Mensaje
        </a>
        <a class="bg-transparent border-2 border-white text-white font-bold py-5 px-10 rounded-full hover:bg-white/10 transition-all flex items-center gap-3" href={getPath('/contacto')}>
          <span class="material-symbols-outlined">description</span> Pedir Cotización
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    // Smooth reveal animations on scroll
    const observerOptions = {
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('opacity-100', 'translate-y-0');
          entry.target.classList.remove('opacity-0', 'translate-y-10');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.glass-card, .bg-surface-container-low').forEach(el => {
      el.classList.add('transition-all', 'duration-700', 'opacity-0', 'translate-y-10');
      observer.observe(el);
    });
  </script>
</Layout>
