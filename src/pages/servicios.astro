<BaseLayout {title} {description}>
<body class="bg-surface text-on-surface font-body-md overflow-x-hidden">
<!-- TopNavBar -->
<nav class="fixed top-0 w-full z-50 bg-surface/95 backdrop-blur-md shadow-md transition-shadow duration-300">
<div class="flex justify-between items-center h-20 px-base md:px-margin-desktop max-w-container-max mx-auto">
<div class="font-display-lg text-display-lg-mobile md:text-headline-lg font-bold text-electric-blue">
                Genesis Electrical
            </div>
<div class="hidden md:flex gap-gutter items-center">
<a class="text-deep-navy font-medium hover:text-electric-blue transition-colors font-label-lg text-label-lg" href="/genesis-corporation">Inicio</a>
<a class="text-electric-blue border-b-2 border-electric-blue font-bold pb-1 font-label-lg text-label-lg" href="servicios">Servicios</a>
<a class="text-deep-navy font-medium hover:text-electric-blue transition-colors font-label-lg text-label-lg" href="sobre-nosotros">Sobre Nosotros</a>
<a class="text-deep-navy font-medium hover:text-electric-blue transition-colors font-label-lg text-label-lg" href="contacto">Contacto</a>
<a class="text-deep-navy font-medium hover:text-electric-blue transition-colors font-label-lg text-label-lg" href="emergencia">Emergencia</a>
<a class="text-deep-navy font-medium hover:text-electric-blue transition-colors font-label-lg text-label-lg" href="faq">FAQ</a>
