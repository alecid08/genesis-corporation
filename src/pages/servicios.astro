<div class="flex items-center gap-4">
<a class="hidden lg:flex items-center gap-2 bg-safety-yellow text-deep-navy px-6 py-2 rounded-lg font-bold hover:brightness-95 transition-all" href="tel:7867202328">
<span class="material-symbols-outlined">call</span>
                    (786) 720-2328
                </a>
<button class="md:hidden text-deep-navy">
<span class="material-symbols-outlined text-3xl">menu</span>
</button>
</div>
</div>
</nav>
<!-- Header Section -->
<header class="relative pt-20 h-[500px] flex items-center overflow-hidden">
<div class="absolute inset-0 bg-deep-navy/70 z-10"></div>
