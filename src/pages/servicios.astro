---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Servicios | Genesis Electrical Corporation";
const description = "Nuestros Servicios Eléctricos en Miami, Florida. Ofrecemos soluciones residenciales, comerciales y especializadas.";
