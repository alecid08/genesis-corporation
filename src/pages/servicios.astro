<script is:inline>
        // Micro-interactions for navigation scroll
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            if (window.scrollY > 50) {
                nav.classList.add('py-2');
                nav.classList.remove('py-0');
            } else {
                nav.classList.add('py-0');
                nav.classList.remove('py-2');
            }
        });

        // Hover animation logic for cards
        document.querySelectorAll('.service-card').forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.querySelector('.material-symbols-outlined').style.transform = 'scale(1.1) translateY(-4px)';
            });
            card.addEventListener('mouseleave', () => {
                card.querySelector('.material-symbols-outlined').style.transform = 'scale(1) translateY(0)';
            });
        });
    </script>
