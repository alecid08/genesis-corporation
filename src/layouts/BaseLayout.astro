---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title = "Genesis Electrical Corporation | Electricistas Profesionales en Miami",
  description = "Servicios eléctricos profesionales residenciales, comerciales y de emergencia 24/7 en Miami, Florida. Electricistas licenciados y certificados.",
  image = "/genesis-corporation/images/og-image.jpg",
  keywords = "electricista miami, servicios electricos, emergencia 24/7, genesis electrical, electricista residencial, electricista comercial"
} = Astro.props;

const siteUrl = 'https://alecid08.github.io/genesis-corporation';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/genesis-corporation') ? image.replace('/genesis-corporation','') : image}`;
const ogImageFull = `${siteUrl}/images/og-image.jpg`;
---

<!DOCTYPE html>
<html class="scroll-smooth" lang="es">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Genesis Electrical Corporation" />
  <meta name="theme-color" content="#003366" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageFull} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="es_US" />
  <meta property="og:site_name" content="Genesis Electrical Corporation" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImageFull} />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

  <!-- Google Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

  <!-- LocalBusiness Schema.org Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Electrician",
      "name": "Genesis Electrical Corporation",
      "description": "Servicios eléctricos residenciales y comerciales en Miami, Florida. Electricistas licenciados y certificados.",
      "image": "https://alecid08.github.io/genesis-corporation/images/og-image.jpg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "185 NW 13th Ave Suite 736",
        "addressLocality": "Miami",
        "addressRegion": "FL",
        "postalCode": "33125",
        "addressCountry": "US"
      },
      "telephone": "+17867202328",
      "email": "info@genesiselectrical.com",
      "url": "https://alecid08.github.io/genesis-corporation",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "07:00",
          "closes": "19:00"
        }
      ],
      "priceRange": "$$",
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 25.7760195,
        "longitude": -80.2185566
      },
      "sameAs": [
        "https://www.facebook.com",
        "https://www.instagram.com"
      ]
    }
  </script>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex flex-col">
  <slot />
</body>
</html>
