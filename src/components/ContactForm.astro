---
---

<div class="bg-[#F9FAFB] p-8 md:p-10 rounded-[12px] shadow-sm border border-outline-variant">
  <h2 class="font-headline-lg text-[32px] font-bold text-deep-navy mb-8">Envíenos un Mensaje</h2>
  
  <form id="contact-form" class="space-y-6">
    <!-- Success/Error Messages -->
    <div id="form-error" class="hidden p-4 bg-red-100 text-red-800 rounded-lg text-sm font-medium">
      Hubo un error al enviar el formulario. Por favor, revise los campos e inténtelo de nuevo.
    </div>

    <div class="space-y-2">
      <label for="name" class="font-label-lg text-deep-navy block font-semibold">Nombre *</label>
      <input 
        id="name"
        name="name"
        required
        class="w-full p-4 rounded-lg border border-outline-variant focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none transition-all bg-white text-body-md" 
        placeholder="Su nombre completo" 
        type="text"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label for="phone" class="font-label-lg text-deep-navy block font-semibold">Teléfono *</label>
        <input 
          id="phone"
          name="phone"
          required
          pattern="[0-9+() \-]{7,20}"
          class="w-full p-4 rounded-lg border border-outline-variant focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none transition-all bg-white text-body-md" 
          placeholder="(786) 000-0000" 
          type="tel"
        />
      </div>
      <div class="space-y-2">
        <label for="email" class="font-label-lg text-deep-navy block font-semibold">Email *</label>
        <input 
          id="email"
          name="email"
          required
          class="w-full p-4 rounded-lg border border-outline-variant focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none transition-all bg-white text-body-md" 
          placeholder="nombre@correo.com" 
          type="email"
        />
      </div>
    </div>

    <div class="space-y-2">
      <label for="service-type" class="font-label-lg text-deep-navy block font-semibold">Tipo de Servicio</label>
      <select 
        id="service-type"
        name="service-type"
        class="w-full p-4 rounded-lg border border-outline-variant focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none transition-all bg-white text-body-md"
      >
        <option value="residencial">Residencial</option>
        <option value="comercial">Comercial</option>
        <option value="emergencia">Emergencia 24/7</option>
      </select>
    </div>

    <div class="space-y-2">
      <label for="address" class="font-label-lg text-deep-navy block font-semibold">Dirección del Proyecto</label>
      <input 
        id="address"
        name="address"
        class="w-full p-4 rounded-lg border border-outline-variant focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none transition-all bg-white text-body-md" 
        placeholder="Calle, Ciudad, Zip Code" 
        type="text"
      />
    </div>

    <div class="space-y-2">
      <label for="message" class="font-label-lg text-deep-navy block font-semibold">Mensaje *</label>
      <textarea 
        id="message"
        name="message"
        required
        class="w-full p-4 rounded-lg border border-outline-variant focus:border-electric-blue focus:ring-2 focus:ring-electric-blue/20 outline-none transition-all bg-white text-body-md" 
        placeholder="Cuéntenos sobre su necesidad..." 
        rows="5"
      ></textarea>
    </div>

    <div class="flex items-center gap-3">
      <input 
        class="w-5 h-5 text-electric-blue rounded border-outline-variant focus:ring-electric-blue focus:ring-2 focus:ring-offset-0 cursor-pointer" 
        id="consent" 
        type="checkbox"
        required
      />
      <label class="text-body-md text-on-surface-variant cursor-pointer select-none" for="consent">
        Acepto recibir comunicaciones por correo electrónico. *
      </label>
    </div>

    <button 
      id="submit-btn"
      class="w-full bg-electric-blue text-white font-bold py-5 rounded-lg hover:bg-deep-navy transition-all duration-300 scale-up text-[18px] flex items-center justify-center gap-2 cursor-pointer focus:outline-none" 
      type="submit"
    >
      <span id="btn-text">Enviar Mensaje</span>
      <span id="btn-spinner" class="hidden animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full"></span>
    </button>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const formError = document.getElementById('form-error');

  if (form && submitBtn && btnText && btnSpinner && formError) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Reset error state
      formError.classList.add('hidden');

      // Simple HTML5 validation check
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Enter loading state
      submitBtn.disabled = true;
      btnText.textContent = 'Enviando...';
      btnSpinner.classList.remove('hidden');

      // Send form submission to API endpoint
      try {
        const formData = new FormData(form);
        const data = {
          name: formData.get('name'),
          phone: formData.get('phone'),
          email: formData.get('email'),
          'service-type': formData.get('service-type'),
          address: formData.get('address'),
          message: formData.get('message'),
        };

        const base = import.meta.env.BASE_URL;
        const response = await fetch(`${base.replace(/\/$/, '')}/api/contact`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          throw new Error('Error de servidor');
        }

        // Redirect to thank you page
        window.location.href = `${base.replace(/\/$/, '')}/gracias`;
      } catch (error) {
        console.error('Submission error:', error);
        formError.classList.remove('hidden');
        
        // Reset button state
        submitBtn.disabled = false;
        btnText.textContent = 'Enviar Mensaje';
        btnSpinner.classList.add('hidden');
      }
    });
  }
</script>
