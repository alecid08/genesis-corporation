---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const getPath = (href: string) => {
  if (href.startsWith('/')) {
    return `${base.replace(/\/$/, '')}${href}`;
  }
  return href;
};
---

<footer class="bg-deep-navy dark:bg-black relative w-full pt-16 pb-8 border-t border-white/10 text-on-primary">
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-gutter px-base md:px-margin-desktop max-w-container-max mx-auto">
    <!-- Brand Info -->
    <div class="flex flex-col gap-6">
      <div class="font-display-lg text-headline-md font-bold text-on-primary">Genesis Electrical</div>
      <p class="text-on-primary/80 font-body-md">
        Líderes en servicios eléctricos industriales, comerciales y residenciales en el área de Miami-Dade.
      </p>
      <div class="flex gap-4">
        <!-- Facebook Icon -->
        <a class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-safety-yellow hover:text-deep-navy transition-all" href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
            <path d="M9 8H7v3h2v9h4v-9h3.6l.4-3H13V6c0-.5.5-1 1-1h2V2h-3a4 4 0 00-4 4v2z"/>
          </svg>
        </a>
        <!-- Instagram Icon -->
        <a class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-safety-yellow hover:text-deep-navy transition-all" href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </a>
      </div>
    </div>
    <!-- Quick Links -->
    <div class="flex flex-col gap-4">
      <h4 class="text-safety-yellow font-bold font-headline-md text-headline-md">Navegación</h4>
      <ul class="flex flex-col gap-2">
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/')}>Inicio</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/servicios')}>Servicios</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/sobre-nosotros')}>Sobre Nosotros</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/contacto')}>Contacto</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/emergencia')}>Emergencias 24/7</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/faq')}>FAQ</a></li>
      </ul>
    </div>
    <!-- Services Links -->
    <div class="flex flex-col gap-4">
      <h4 class="text-safety-yellow font-bold font-headline-md text-headline-md">Nuestros Servicios</h4>
      <ul class="flex flex-col gap-2">
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/servicios#residencial')}>Residencial</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/servicios#comercial')}>Comercial</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/emergencia')}>Emergencias</a></li>
        <li><a class="text-on-primary/80 hover:text-safety-yellow transition-colors hover:translate-x-1 inline-block font-body-md" href={getPath('/servicios#mantenimiento')}>Mantenimiento</a></li>
      </ul>
    </div>
    <!-- Contact Info -->
    <div class="flex flex-col gap-4">
      <h4 class="text-safety-yellow font-bold font-headline-md text-headline-md">Contacto</h4>
      <p class="flex items-start gap-3 text-on-primary/80 font-body-md">
        <span class="material-symbols-outlined text-safety-yellow">location_on</span>
        <span>185 NW 13th Ave, Miami, FL 33125</span>
      </p>
      <p class="flex items-center gap-3 text-on-primary/80 font-body-md">
        <span class="material-symbols-outlined text-safety-yellow">call</span>
        <a href="tel:+17867202328" class="hover:text-safety-yellow transition-colors">(786) 720-2328</a>
      </p>
      <p class="flex items-center gap-3 text-on-primary/80 font-body-md">
        <span class="material-symbols-outlined text-safety-yellow">mail</span>
        <a href="mailto:info@genesiselectrical.com" class="hover:text-safety-yellow transition-colors">info@genesiselectrical.com</a>
      </p>
    </div>
  </div>
  <div class="max-w-container-max mx-auto px-base md:px-margin-desktop mt-16 pt-8 border-t border-white/10 text-center">
    <p class="text-on-primary/60 font-label-md text-label-md">© {currentYear} Genesis Electrical Corporation. Todos los derechos reservados.</p>
  </div>
</footer>
