---
interface Props {
  title: string;
  subtitle: string;
  description?: string;
  backgroundImage: string;
  primaryCTA: { text: string; href: string };
  secondaryCTA?: { text: string; href: string };
}

const { title, subtitle, description, backgroundImage, primaryCTA, secondaryCTA } = Astro.props;
---

<section class="relative min-h-[600px] md:h-[819px] flex items-center overflow-hidden py-16 md:py-0">
  <div class="absolute inset-0 z-0">
    <div 
      class="w-full h-full bg-cover bg-center" 
      style={`background-image: url('${backgroundImage}')`}
    ></div>
    <div class="absolute inset-0 bg-primary/50 mix-blend-multiply"></div>
  </div>
  <div class="relative z-10 px-base md:px-margin-desktop max-w-container-max mx-auto w-full">
    <div class="max-w-2xl text-on-primary">
      <h1 class="font-display-lg text-4xl md:text-[60px] md:leading-[1.1] font-bold mb-6">
        {title}
      </h1>
      <p class="font-headline-md text-xl md:text-headline-md mb-8 opacity-90">
        {subtitle}
      </p>
      {description && (
        <p class="font-body-lg text-lg mb-8 opacity-80">
          {description}
        </p>
      )}
      <div class="flex flex-wrap gap-4">
        <a 
          href={primaryCTA.href} 
          class="bg-safety-yellow text-deep-navy font-bold py-3.5 px-6 md:py-4 md:px-8 rounded-lg shadow-lg hover:brightness-95 transition-all text-base md:text-lg text-center"
        >
          {primaryCTA.text}
        </a>
        {secondaryCTA && (
          <a 
            href={secondaryCTA.href} 
            class="bg-transparent border-2 border-white text-white font-bold py-3.5 px-6 md:py-4 md:px-8 rounded-lg hover:bg-white/10 transition-all text-base md:text-lg text-center"
          >
            {secondaryCTA.text}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
